# =============================================================================
# SOVEREIGN-SRE ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------------------------------------
# GitHub Integration (for autonomous PRs)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=Sovereign-SRE

# -----------------------------------------------------------------------------
# Service URLs (Docker internal networking)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434
CHROMA_HOST=http://chromadb:8000
MCP_SERVER_HOST=http://mcp-server:8080

# -----------------------------------------------------------------------------
# Local Development Overrides
# -----------------------------------------------------------------------------
# Uncomment these when running services locally (not in Docker)
# OLLAMA_HOST=http://localhost:11434
# CHROMA_HOST=http://localhost:8000
# MCP_SERVER_HOST=http://localhost:8080

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
OLLAMA_LLM_MODEL=llama3.3
OLLAMA_EMBED_MODEL=bge-m3

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
CHROMA_COLLECTION_NAME=sovereign_sre_codebase
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
HUMAN_APPROVAL_REQUIRED=true
MAX_AUTO_FIX_ATTEMPTS=3
