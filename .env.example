# =============================================================================
# SOVEREIGN-SRE ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# LLM Provider (groq | grok | claude)
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq

# -----------------------------------------------------------------------------
# Groq API — Llama 3.3 on LPU hardware (default, free tier available)
# Get your key at: https://console.groq.com
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# Available Groq models:
# llama-3.3-70b-versatile  → best quality (RCA + patch generation)
# llama-3.1-8b-instant     → fastest / cheapest (simple classification)
# mixtral-8x7b-32768       → long context (32K window)
# gemma2-9b-it             → lightweight alternative
GROQ_MODEL=llama-3.3-70b-versatile

# -----------------------------------------------------------------------------
# xAI Grok API (optional, set LLM_PROVIDER=grok to activate)
# Get your key at: https://console.x.ai
# -----------------------------------------------------------------------------
# XAI_API_KEY=your_xai_api_key_here
# GROK_MODEL=grok-3-mini

# -----------------------------------------------------------------------------
# Anthropic Claude API (optional, set LLM_PROVIDER=claude to activate)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# GitHub Integration (for autonomous PRs)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=Sovereign-SRE

# -----------------------------------------------------------------------------
# Service URLs (Docker internal networking)
# -----------------------------------------------------------------------------
CHROMA_HOST=http://chromadb:8000
MCP_SERVER_HOST=http://mcp-server:8080

# -----------------------------------------------------------------------------
# Local Development Overrides
# -----------------------------------------------------------------------------
# Uncomment these when running services locally (not in Docker)
# CHROMA_HOST=http://localhost:8000
# MCP_SERVER_HOST=http://localhost:8080

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------
EMBED_MODEL=BAAI/bge-m3

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
CHROMA_COLLECTION_NAME=sovereign_sre_codebase
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
HUMAN_APPROVAL_REQUIRED=true
MAX_AUTO_FIX_ATTEMPTS=3
